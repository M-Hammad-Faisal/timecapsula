# ─────────────────────────────────────────────
# TimeCapsula — Environment Variables
# ─────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────
# Settings → Integrations → Data API → URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Settings → API Keys → Publishable key (sb_publishable_...) — safe for browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Settings → API Keys → Secret key (sb_secret_...) — server only, never expose
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── RESEND ────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── CRON ──────────────────────────────────────
CRON_SECRET=your-random-secret-string-here
