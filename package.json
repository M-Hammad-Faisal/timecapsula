  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/lib/__tests__/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
