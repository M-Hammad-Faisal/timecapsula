# ─────────────────────────────────────────────
# TimeCapsula — Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your values
# 3. Add ALL of these in Vercel → Settings → Environment Variables
# 4. Add RESEND_API_KEY + CRON_SECRET in Supabase → Edge Functions → Secrets

# ── SUPABASE ──────────────────────────────────
# Settings → Integrations → Data API → URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Settings → API Keys → Secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── RESEND (email delivery) ───────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── CRON SECRET (protects your edge function) ─
# Make up any random string — used to authenticate cron calls
# Generate one: openssl rand -hex 32
CRON_SECRET=your-random-secret-string-here

# ⚠️  NEXT_PUBLIC_SUPABASE_URL  → safe to expose (public)
# ⚠️  All others               → NEVER commit, NEVER expose client-side
